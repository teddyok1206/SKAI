# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Provider selection
SKAI_DEFAULT_PROVIDER=mock
SKAI_DEFAULT_MODEL=mock-orchestrator

# Judge pipeline
# heuristic: deterministic local baseline
# llm: heuristic fallback plus one LLM judge
# ensemble: heuristic fallback plus multiple LLM judges
SKAI_JUDGE_MODE=heuristic
SKAI_JUDGE_PROVIDER=gemini
SKAI_JUDGE_MODEL=gemini-2.5-flash-lite
SKAI_JUDGE_ENSEMBLE=gemini:gemini-2.5-flash-lite,openai:gpt-4.1-mini

# OpenAI-compatible providers. Do not commit real values.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Budget guardrails
SKAI_MAX_TURNS_PER_ATTEMPT=18
SKAI_MAX_INPUT_CHARS_PER_TURN=6000
