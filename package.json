{
  "name": "skai",
  "version": "1.0.0",
  "private": true,
  "description": "SKAI demo: AI orchestration practice, feedback, and sharing.",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start",
    "serve:local": "next start -H 127.0.0.1 -p 3000",
    "serve:lan": "next start -H 0.0.0.0 -p 3000",
    "calibrate:judge": "node scripts/judge_calibration_smoke.mjs",
    "skai:fixtures": "node scripts/generate_skai_fixtures.mjs",
    "skai:validate": "node scripts/skai_validate.mjs fixtures/skai",
    "skai:viewer-smoke": "node scripts/skai_viewer_fixture_smoke.mjs",
    "judge:fixture": "node scripts/judge_fixture.mjs --write",
    "judge:regression": "node scripts/judge_fixture.mjs --regression",
    "verify:skai": "npm run skai:validate && npm run skai:viewer-smoke && npm run judge:regression && npm run typecheck && npm run lint",
    "smoke:live": "node scripts/live_provider_smoke.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "keywords": [
    "ai",
    "orchestration",
    "education",
    "prompting"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "clsx": "^2.1.1",
    "katex": "^0.17.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.6",
    "pretendard": "^1.3.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.15",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
